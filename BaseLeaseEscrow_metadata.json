		"devdoc": {
			"details": "Enterprise-grade smart contract for rental security deposits and rent tracking. * Features: - Immutable Rent Receipts. - Two-party consent required for deposit deductions. - Third-party arbitration fallback for disputes. - Reentrancy protection for all financial transfers.",
			"kind": "dev",
			"methods": {
				"createLease(address,address,uint256,uint256)": {
					"details": "Landlord creates the lease terms."
				},
				"fundDeposit(uint256)": {
					"details": "Tenant reviews the terms and funds the security deposit to lock the contract."
				},
				"payRent(uint256)": {
					"details": "Tenant pays monthly rent. Funds are routed instantly to Landlord. This creates an immutable blockchain receipt of rent payment."
				},
				"proposeDeduction(uint256,uint256,uint256)": {
					"details": "Lease ends. Landlord proposes how the deposit should be split. e.g., Full refund, or a deduction for damages."
				},
				"raiseDispute(uint256)": {
					"details": "Tenant disagrees with deductions. Freezes the contract for Arbitration."
				},
				"resolveDispute(uint256,uint256,uint256)": {
					"details": "Neutral Arbiter resolves the dispute with final binding split."
				},
				"tenantAgree(uint256)": {
					"details": "Tenant agrees to the proposed split. Funds are distributed safely."
				}
			},
			"title": "BaseLeaseEscrow",
			"version": 1
		},
